{
  "manifest_version": 3,
  "name": "YouTube Member Posts Reader",
  "version": "1.1.1.1",
  "description": "__MSG_appDescription__",
  "author": "cjzopen",
  "default_locale": "en",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.ytimg.com/*",
    "*://*.ggpht.com/*"
  ],
  "action": {
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    },
    "default_title": "__MSG_actionTitle__",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}